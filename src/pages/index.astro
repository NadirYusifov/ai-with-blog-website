---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Hero3D from '../components/Hero3D.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="My Blog - Home" description="Welcome to my blog where I share thoughts on web development">
  <section class="mb-16 text-center animate-fade-in">
    <h1 class="text-5xl font-extrabold mb-6 bg-gradient-to-r from-cyan-400 via-purple-400 to-pink-400 bg-clip-text text-transparent animate-gradient">
      Welcome to My Blog
    </h1>
    <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed animate-fade-in delay-200">
      I'm a web developer sharing insights about Astro, JavaScript, and modern web development.
    </p>
  </section>

  <!-- Three.js 3D Hero Section -->
  <section class="mb-16 animate-fade-in delay-250">
    <Hero3D />
  </section>

  <section class="animate-fade-in delay-300">
    <h2 class="text-3xl font-bold mb-8 text-gray-100 flex items-center gap-3">
      <span class="w-2 h-8 bg-gradient-to-b from-cyan-400 to-purple-400 rounded-full animate-pulse-slow"></span>
      Recent Posts
    </h2>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post, index) => (
        <a href={`/blog/${post.id}/`} class="block group animate-fade-in" style={`animation-delay: ${0.4 + index * 0.1}s`}>
          <article class="bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 overflow-hidden hover:bg-white/10 hover:border-cyan-400/50 hover:shadow-2xl hover:shadow-cyan-500/20 transition-all duration-300 transform hover:-translate-y-2">
            {post.data.heroImage && (
              <div class="overflow-hidden">
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="w-full h-48 object-cover group-hover:scale-110 transition-transform duration-500"
                />
              </div>
            )}
            <div class="p-6">
              <h3 class="text-xl font-bold mb-3 bg-gradient-to-r from-cyan-300 to-purple-300 bg-clip-text text-transparent group-hover:from-cyan-200 group-hover:to-purple-200 transition-all">
                {post.data.title}
              </h3>
              <p class="text-gray-400 mb-4 line-clamp-2 leading-relaxed">{post.data.description}</p>
              <div class="flex items-center justify-between">
                <time class="text-sm text-gray-500 flex items-center gap-2">
                  <span class="w-1.5 h-1.5 bg-cyan-400 rounded-full animate-pulse-slow"></span>
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                <span class="text-cyan-400 group-hover:translate-x-1 transition-transform">→</span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
