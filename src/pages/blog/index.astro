---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog - My Blog" description="All blog posts">
  <h1 class="text-5xl font-extrabold mb-10 bg-gradient-to-r from-cyan-400 via-purple-400 to-pink-400 bg-clip-text text-transparent text-center">
    All Blog Posts
  </h1>
  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => (
      <a href={`/blog/${post.id}/`} class="block group">
        <article class="bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 overflow-hidden hover:bg-white/10 hover:border-cyan-400/50 hover:shadow-2xl hover:shadow-cyan-500/20 transition-all duration-300 transform hover:-translate-y-2">
          {post.data.heroImage && (
            <div class="overflow-hidden">
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                class="w-full h-48 object-cover group-hover:scale-110 transition-transform duration-500"
              />
            </div>
          )}
          <div class="p-6">
            <h3 class="text-xl font-bold mb-3 bg-gradient-to-r from-cyan-300 to-purple-300 bg-clip-text text-transparent group-hover:from-cyan-200 group-hover:to-purple-200 transition-all">
              {post.data.title}
            </h3>
            <p class="text-gray-400 mb-4 line-clamp-2 leading-relaxed">{post.data.description}</p>
            <div class="flex items-center justify-between">
              <time class="text-sm text-gray-500 flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></span>
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <span class="text-cyan-400 group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </article>
      </a>
    ))}
  </div>
</BaseLayout>
