---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import type { CollectionEntry } from 'astro:content';

// Type-safe interface with explicit types
interface FrontmatterData {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags: string[];
  draft?: boolean;
  author?: string;
  readingTime?: number;
}

interface Props {
  frontmatter: FrontmatterData;
}

// Type-safe props extraction with defaults
const { frontmatter }: Props = Astro.props;

// Type-safe image URL handling
const heroImageUrl: string | undefined = frontmatter.heroImage;
const authorName: string = frontmatter.author ?? 'Admin';
const readingTimeMinutes: number | undefined = frontmatter.readingTime;
---

<BaseLayout 
  title={frontmatter.title} 
  description={frontmatter.description} 
  image={heroImageUrl}
>
  <article class="max-w-4xl">
    {heroImageUrl !== undefined && heroImageUrl !== null && (
      <div class="mb-8 rounded-2xl overflow-hidden border border-white/10 shadow-2xl">
        <img
          src={heroImageUrl}
          alt={frontmatter.title}
          class="w-full h-64 md:h-96 object-cover"
          loading="lazy"
          width="800"
          height="400"
          decoding="async"
        />
      </div>
    )}
    
    <div class="mb-10">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 bg-gradient-to-r from-cyan-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
        {frontmatter.title}
      </h1>
      
      <div class="flex flex-wrap items-center gap-4 text-gray-400">
        <time datetime={frontmatter.pubDate.toISOString()} class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></span>
          {frontmatter.pubDate.toLocaleDateString('en-US', { 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
          })}
        </time>
        
        {frontmatter.updatedDate !== undefined && (
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-purple-400 rounded-full"></span>
            Updated: 
            <time datetime={frontmatter.updatedDate.toISOString()}>
              {frontmatter.updatedDate.toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
              })}
            </time>
          </span>
        )}
        
        {readingTimeMinutes !== undefined && (
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-pink-400 rounded-full"></span>
            {readingTimeMinutes} min read
          </span>
        )}
        
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></span>
          By {authorName}
        </span>
      </div>
      
      {frontmatter.tags !== undefined && frontmatter.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6" role="list" aria-label="Tags">
          {frontmatter.tags.map((tag: string, index: number) => (
            <span 
              key={`${tag}-${index}`} 
              class="px-3 py-1.5 bg-gradient-to-r from-cyan-500/20 to-purple-500/20 text-cyan-300 text-sm rounded-full border border-cyan-400/30 hover:border-cyan-400/50 transition-colors"
              role="listitem"
            >
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
    
    <div class="prose prose-lg prose-invert max-w-none bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 p-8">
      <slot />
    </div>
  </article>
  
  <Giscus />
</BaseLayout>
